---
// Replace FORMSPREE_ID with your real Formspree form ID (free at formspree.io)
const FORMSPREE_ID = 'FORMSPREE_ID';
---

<section id="waitlist" class="py-20 px-6">
  <div class="max-w-xl mx-auto text-center">

    <h2 class="font-heading text-2xl md:text-3xl text-ink mb-3">Be the first to know</h2>
    <p class="font-body text-sm text-ink/60 mb-8">
      Leave your email and we'll notify you the moment Sylvelle launches on the app stores.
    </p>

    <form
      action={`https://formspree.io/f/${FORMSPREE_ID}`}
      method="POST"
      class="flex flex-col sm:flex-row gap-3"
    >
      <input
        type="email"
        name="email"
        required
        placeholder="your@email.com"
        aria-label="Email address"
        class="flex-1 border border-linen bg-marble px-4 py-3 font-body text-sm text-ink placeholder:text-ink/40 focus:outline-none focus:border-copper transition-colors"
      />
      <button
        type="submit"
        class="bg-ink text-alabaster font-body text-sm font-medium px-6 py-3 tracking-wide hover:bg-ink/80 transition-colors whitespace-nowrap"
      >
        Notify me
      </button>
    </form>

    <p class="font-body text-xs text-ink/40 mt-4">
      No spam. One email when we launch. Unsubscribe any time.
    </p>

  </div>
</section>
