---
---

<section class="relative overflow-hidden pt-20 pb-24 px-6">
  <!-- Subtle texture overlay -->
  <div class="absolute inset-0 opacity-30 pointer-events-none"
    style="background-image: radial-gradient(circle at 70% 20%, #E6AA6820 0%, transparent 60%), radial-gradient(circle at 20% 80%, #B58A7C15 0%, transparent 50%);">
  </div>

  <div class="relative max-w-3xl mx-auto text-center">

    <!-- Logo mark -->
    <div class="mb-8 flex justify-center">
      <img
        src="/logo.png"
        alt="Sylvelle logo mark"
        class="h-24 w-auto opacity-90"
        width="192"
        height="192"
      />
    </div>

    <!-- Wordmark -->
    <h1 class="font-display text-5xl md:text-6xl tracking-[0.2em] text-ink mb-4">
      Sylvelle
    </h1>

    <!-- Divider line -->
    <div class="mx-auto mb-6 h-px w-16 bg-copper opacity-60"></div>

    <!-- Tagline -->
    <p class="font-heading text-xl md:text-2xl text-ink/70 font-normal leading-relaxed mb-4">
      Your private companion for becoming your best self.
    </p>
    <p class="font-body text-base text-ink/50 max-w-xl mx-auto mb-10">
      Style. Fitness. Confidence. Mindset. All on your device — encrypted, offline, no account needed. Free, always.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#download"
        class="inline-flex items-center gap-2 bg-ink text-alabaster font-body text-sm font-medium px-8 py-3 rounded-none tracking-wide hover:bg-ink/80 transition-colors"
      >
        Get the App
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a
        href="#waitlist"
        class="inline-flex items-center gap-2 border border-copper text-copper font-body text-sm font-medium px-8 py-3 rounded-none tracking-wide hover:bg-copper/10 transition-colors"
      >
        Join the Waitlist
      </a>
    </div>

  </div>
</section>
