---

<section id="download" class="py-20 px-6 bg-marble border-y border-linen">
  <div class="max-w-3xl mx-auto text-center">

    <h2 class="font-heading text-3xl md:text-4xl text-ink mb-3">Get Sylvelle</h2>
    <p class="font-body text-ink/60 mb-10">
      Available for Android. iOS is coming after launch.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">

      <!-- Google Play (placeholder) -->
      <a
        href="#"
        aria-label="Get it on Google Play (coming soon)"
        class="inline-flex items-center gap-3 border border-linen bg-alabaster hover:border-copper/40 transition-colors px-6 py-3 w-full sm:w-auto justify-center opacity-60 cursor-not-allowed"
        title="Coming to Google Play"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-ink/70" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.18 23.76c.27.15.57.24.89.24.44 0 .85-.15 1.19-.41L14.5 12 5.26.41A1.97 1.97 0 004.07 0c-.32 0-.62.09-.89.24C2.47.87 2 1.68 2 2.6v18.8c0 .92.47 1.73 1.18 2.36z"/>
          <path d="M20.09 10.27L17.2 8.6l-3.4 3.4 3.4 3.4 2.93-1.67c.83-.48 1.37-1.2 1.37-1.73s-.54-1.25-1.41-1.73z"/>
          <path d="M5.26.41L14.5 12 5.26 23.59l9.63-5.49 2.31-1.32-3.4-3.4L5.26.41z" opacity=".6"/>
          <path d="M5.26.41L13.8 8.92l-8.54-8.51z" opacity=".3"/>
        </svg>
        <div class="text-left">
          <div class="font-body text-xs text-ink/50">Coming soon</div>
          <div class="font-body text-sm font-medium text-ink/70">Google Play</div>
        </div>
      </a>

      <!-- App Store (placeholder) -->
      <a
        href="#"
        aria-label="Download on the App Store (coming soon)"
        class="inline-flex items-center gap-3 border border-linen bg-alabaster hover:border-copper/40 transition-colors px-6 py-3 w-full sm:w-auto justify-center opacity-60 cursor-not-allowed"
        title="Coming to the App Store"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-ink/70" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <div class="font-body text-xs text-ink/50">Coming soon</div>
          <div class="font-body text-sm font-medium text-ink/70">App Store</div>
        </div>
      </a>

      <!-- Direct APK -->
      <a
        href="#"
        aria-label="Download APK directly (Android)"
        class="inline-flex items-center gap-3 border border-copper/60 bg-alabaster hover:bg-copper/5 transition-colors px-6 py-3 w-full sm:w-auto justify-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-copper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <div class="text-left">
          <div class="font-body text-xs text-copper/70">Android · Sideload</div>
          <div class="font-body text-sm font-medium text-copper">Download APK</div>
        </div>
      </a>

    </div>

    <p class="font-body text-xs text-ink/40 mt-6">
      The direct APK is the full adult edition. Store versions coming soon.
    </p>

  </div>
</section>
