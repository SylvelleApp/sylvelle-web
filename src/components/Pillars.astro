---
const pillars = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Style & Beauty',
    body: 'Skincare, makeup, hair, wardrobe building, personal style. At your own pace, your own way.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
    title: 'Fitness & Wellness',
    body: 'Strength, mobility, posture, energy — framed around health and confidence, never weight-loss pressure.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
    title: 'Confidence & Social',
    body: 'Poise, vocal presence, conversation, charm, public-speaking confidence. Platonic and empowering.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
    title: 'Mindset & Life',
    body: 'Self-talk, emotional resilience, habits, journaling — plus career, finances, and productivity.',
  },
];
---

<section id="features" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-14">
      <h2 class="font-heading text-3xl md:text-4xl text-ink mb-3">Four pillars of growth</h2>
      <p class="font-body text-ink/60 max-w-lg mx-auto">
        Everything Sylvelle coaches lives in one of these areas — and you choose which ones matter most to you.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {pillars.map(({ icon, title, body }) => (
        <div class="bg-marble border border-linen p-8 group hover:border-copper/40 transition-colors">
          <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-copper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icon} />
          </div>
          <h3 class="font-heading text-lg text-ink mb-2">{title}</h3>
          <p class="font-body text-sm text-ink/60 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
