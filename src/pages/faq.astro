---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    q: 'Is Sylvelle free?',
    a: 'Yes — completely free. No in-app purchases, no subscriptions, no paywalls. Donations are welcome but never required.',
  },
  {
    q: 'Do I need to create an account?',
    a: 'No account, no sign-up, no email. The app works fully without one. Your identity stays entirely on your device.',
  },
  {
    q: 'Does it need an internet connection?',
    a: 'No. Sylvelle is offline-first — everything runs locally on your device. The optional AI coach requires an internet connection only when you choose to use it.',
  },
  {
    q: 'Is my data private?',
    a: 'Yes. No analytics, no trackers, no cloud storage. Everything is AES-256 encrypted on your phone, protected by a passphrase you choose.',
  },
  {
    q: 'What if I lose my phone?',
    a: 'Your data is encrypted on-device. Without your passphrase, no one can read it — including us. We recommend keeping a secure backup of your passphrase.',
  },
  {
    q: 'Who is Sylvelle for?',
    a: 'Any woman who wants a structured, private companion for self-improvement — whether that\'s style, fitness, confidence, mindset, or all four. There\'s no single "right" starting point.',
  },
  {
    q: 'Is there a version for teens?',
    a: 'Yes. The Teen Edition (ages 13–17) is a separate build with extra safety guardrails: capped coaching intensity, mature content removed, and age-appropriate resources.',
  },
  {
    q: 'Is it Android only?',
    a: 'For now, yes. iOS is the next platform after the Android launch. Join the waitlist to be notified.',
  },
  {
    q: 'What is the optional AI coach?',
    a: 'An on-device-memory AI companion that brings the coaching grid to life in natural conversation. It requires your own API key (from a provider of your choice) and an internet connection. The engine delivers full value without it.',
  },
  {
    q: 'Is the source code open?',
    a: 'Not currently. Sylvelle is closed-source to protect the quality of its content and user experience.',
  },
];
---

<Layout
  title="FAQ — Sylvelle"
  description="Frequently asked questions about Sylvelle."
>
  <Header />
  <main class="max-w-3xl mx-auto px-6 py-20">

    <div class="text-center mb-16">
      <h1 class="font-display text-4xl tracking-widest text-ink mb-4">FAQ</h1>
      <div class="mx-auto h-px w-12 bg-copper opacity-60"></div>
    </div>

    <div class="space-y-px">
      {faqs.map(({ q, a }) => (
        <details class="group border border-linen bg-marble open:border-copper/30 transition-colors">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-heading text-base text-ink hover:text-copper transition-colors">
            {q}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-copper shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="px-6 pb-5 font-body text-sm text-ink/60 leading-relaxed border-t border-linen mt-0 pt-4">
            {a}
          </p>
        </details>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="font-body text-sm text-ink/50">
        More questions? <a href="https://instagram.com/sylvelle" target="_blank" rel="noopener noreferrer" class="text-copper hover:underline">Find us on Instagram.</a>
      </p>
    </div>

  </main>
  <Footer />
</Layout>
