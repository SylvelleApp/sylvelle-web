---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SupportCard from '../components/SupportCard.astro';

const cards = [
  {
    title: 'Ko-fi',
    description: 'A one-time or monthly donation — whatever feels right. Every contribution helps keep Sylvelle maintained and growing.',
    href: 'https://ko-fi.com/PLACEHOLDER',
    label: 'Support on Ko-fi',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
  {
    title: 'Patreon',
    description: 'Monthly tiers with behind-the-scenes development updates. See what\'s being built, why, and what\'s coming next.',
    href: 'https://patreon.com/PLACEHOLDER',
    label: 'Join on Patreon',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />`,
  },
  {
    title: 'Send a Gift',
    description: 'Want to send something more personal? Browse the wishlist and send a gift directly to the creator — no address required.',
    note: 'Throne acts as a shipping proxy: you buy an item, they forward it to the creator. Your address and the creator\'s address are never shared with each other.',
    href: 'https://throne.com/PLACEHOLDER',
    label: 'View Wishlist on Throne',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />`,
  },
];
---

<Layout
  title="Support Sylvelle"
  description="Sylvelle is free and always will be. If you'd like to support its development, here's how."
>
  <Header />
  <main class="max-w-5xl mx-auto px-6 py-20">

    <div class="text-center mb-16">
      <h1 class="font-display text-4xl tracking-widest text-ink mb-4">Support the Project</h1>
      <div class="mx-auto mb-6 h-px w-12 bg-copper opacity-60"></div>
      <p class="font-body text-ink/60 max-w-lg mx-auto leading-relaxed">
        Sylvelle is free and always will be. If you'd like to help keep it alive and growing —
        thank you. It means more than you know.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map((card) => (
        <SupportCard {...card} />
      ))}
    </div>

    <div class="mt-16 text-center border-t border-linen pt-10">
      <p class="font-body text-sm text-ink/40 italic">
        Every donation goes directly toward development time, hosting, and keeping the app free for everyone.
      </p>
    </div>

  </main>
  <Footer />
</Layout>
